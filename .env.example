# Skopiuj do .env.local i uzupełnij po utworzeniu projektu Supabase.
# Bez tych zmiennych aplikacja działa jak dotychczas (data/app-data.json).

# Supabase — Project Settings → API
SUPABASE_URL=https://twoj-projekt.supabase.co
# Tylko po stronie serwera (Next.js API). Nigdy w kodzie klienta / przeglądarce.
SUPABASE_SERVICE_ROLE_KEY=

# Opcjonalnie: Vercel Blob (gdy brak Supabase, a token jest ustawiony)
# BLOB_READ_WRITE_TOKEN=
